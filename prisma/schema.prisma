generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  READ
}

enum ChannelRole {
  ADMIN
  PUBLISHER
  SUBSCRIBER
}

enum NotificationPriority {
  HIGH
  MEDIUM
  LOW
  NONE
}

model User {
  username          String             @id
  fullName          String
  email             String             @unique
  passwordHash      String
  refreshTokens     RefreshToken[]
  notifications     Notification[]     @relation("SenderNotifications")
  channelMembers    ChannelMember[]
  pushSubscriptions PushSubscription[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Channel {
  id            String          @id @default(uuid())
  title         String
  members       ChannelMember[]
  notifications Notification[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
}

model RefreshToken {
  id          String   @id @default(uuid())
  hashedToken String
  userId      String
  user        User     @relation(fields: [userId], references: [username], onDelete: Cascade)
  expiresAt   DateTime
  userAgent   String?
  ip          String?
  createdAt   DateTime @default(now())
}

model ChannelMember {
  channelId        String
  channel          Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId           String
  user             User        @relation(fields: [userId], references: [username], onDelete: Cascade)
  role             ChannelRole @default(SUBSCRIBER)
  joinedAt         DateTime    @default(now())
  lastReadSequence Int         @default(0)

  @@id([channelId, userId])
}

model Notification {
  id                   String               @id @default(uuid())
  clientNotificationId String?              @unique
  sequence             Int                  @unique @default(autoincrement())
  channelId            String
  channel              Channel              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId             String
  sender               User                 @relation("SenderNotifications", fields: [senderId], references: [username])
  text                 String
  priority             NotificationPriority @default(MEDIUM)
  parentNotificationId String?
  parentNotification   Notification?        @relation("Thread", fields: [parentNotificationId], references: [id], onDelete: SetNull)
  replies              Notification[]       @relation("Thread")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([text(ops: raw("gin_trgm_ops"))], type: Gin)
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [username], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
